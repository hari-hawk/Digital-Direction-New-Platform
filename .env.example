# Digital Direction — Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://dd_user:dd_local_dev@localhost:5432/digital_direction
DATABASE_URL_SYNC=postgresql+psycopg2://dd_user:dd_local_dev@localhost:5432/digital_direction

# ═══════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# STORAGE
# ═══════════════════════════════════════════════════════════════
STORAGE_BACKEND=local
STORAGE_BASE_DIR=./storage
# For GCS: set to "gcs" and provide bucket name
GCS_BUCKET_NAME=

# ═══════════════════════════════════════════════════════════════
# LLM — BACKEND & MODELS
# ═══════════════════════════════════════════════════════════════
# Backend: "aistudio" (default, simple) or "vertex" (GCP, better reliability)
LLM_BACKEND=aistudio

# Gemini (extraction)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_COMPLEX_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_MAX_CONCURRENT=200

# Claude (merge + eval)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MERGE_MODEL=claude-sonnet-4-6
CLAUDE_COMPLEX_MODEL=claude-opus-4-6
CLAUDE_EVAL_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=8192
CLAUDE_MAX_CONCURRENT=10

# Vertex AI (only if LLM_BACKEND=vertex)
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ═══════════════════════════════════════════════════════════════
# LLM — RATE LIMITING & COST CONTROLS
# ═══════════════════════════════════════════════════════════════
LLM_RETRY_DELAYS=[1, 2, 4, 8, 16]
MAX_SPEND_USD=100.0
SPEND_WARN_PCT=0.8

SECTION_TIMEOUT=600
EXTRACTION_BATCH_SIZE=50

# ═══════════════════════════════════════════════════════════════
# LANGFUSE — LLM OBSERVABILITY (POC SETUP)
# ═══════════════════════════════════════════════════════════════
# Set to true to enable LangFuse tracing
LANGFUSE_ENABLED=true

# Local LangFuse setup (docker compose)
LANGFUSE_PUBLIC_KEY=pk-lf-test-key
LANGFUSE_SECRET_KEY=sk-lf-test-key
LANGFUSE_HOST=http://localhost:3100

# Alternative: LangFuse Cloud (production)
# LANGFUSE_PUBLIC_KEY=pk-prod-xxxxxxx
# LANGFUSE_SECRET_KEY=sk-prod-xxxxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════════
CORS_ORIGINS=["http://localhost:3000"]

# ═══════════════════════════════════════════════════════════════
# APP
# ═══════════════════════════════════════════════════════════════
APP_NAME=Digital Direction
DEBUG=true
